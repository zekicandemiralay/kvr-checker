# -----------------------------------------------
# KVR Munich Appointment Checker — Configuration
# -----------------------------------------------
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Email (Gmail) ──────────────────────────────
# Sender Gmail address (the "bot" account)
EMAIL_FROM=your_bot@gmail.com

# Where to send the alert (your personal email)
EMAIL_TO=your_personal@gmail.com

# Gmail App Password — NOT your regular Gmail password!
# How to get one:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification
#   3. Search "App passwords" → create one for Mail
#   4. Paste the 16-character code below (spaces optional)
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ── Telegram ───────────────────────────────────
# How to set up:
#   1. Open Telegram → search @BotFather → send /newbot
#   2. Follow the prompts → copy the token you receive
#   3. Send ANY message to your new bot (e.g. "hello")
#   4. Open https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#   5. Find "chat": {"id": 123456789} → that number is your chat ID
TELEGRAM_BOT_TOKEN=123456:ABC-DEF-your-token-here
TELEGRAM_CHAT_ID=123456789

# ── General ────────────────────────────────────
# How often to check for appointments (seconds). Default: 60
CHECK_INTERVAL=60
